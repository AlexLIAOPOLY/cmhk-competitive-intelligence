DS_API_KEY=your_deepseek_api_key
TAVILY_API_KEY=your_tavily_api_key

# Service
PORT=3000
NODE_ENV=production

# Scheduler
SCAN_SCHEDULE=*/30 * * * *
SCAN_TIMEZONE=Asia/Hong_Kong
SCAN_INTERVAL_MINUTES=30

# Search / AI
DS_MODEL=deepseek-chat
DS_TIMEOUT_MS=30000
DS_REPORT_TIMEOUT_MS=420000
DS_REPORT_QA_TIMEOUT_MS=180000
TAVILY_TIMEOUT_MS=15000
MAX_RESULTS_PER_QUERY=8

# Storage
# For Render with persistent disk, set DATA_DIR=/var/data
DATA_DIR=./data
# Optional: override full db file path
# DB_PATH=./data/db.json

# PDF high-fidelity export (Puppeteer)
# Set in Render Docker runtime to /usr/bin/chromium
# CHROME_PATH=/usr/bin/chromium
